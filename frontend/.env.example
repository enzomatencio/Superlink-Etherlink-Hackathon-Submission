# Superlink Frontend Configuration

# Domain type - determines which UI to show
VITE_SITE_TYPE=app

# Admin wallet address for admin panel access  
VITE_ADMIN_ADDRESS=YOUR_ADMIN_WALLET_ADDRESS

# Contract addresses on Etherlink Mainnet
VITE_VAULT_ADDRESS=0x1F2C64c792ea49991D5efd350B15c0e043e402Ce
VITE_USDC_ADDRESS=0x796Ea11Fa2dD751eD01b53C372fFDB4AAa8f00F9
VITE_USDT_ADDRESS=0x2C03058C8AFC06713be23e58D2febC8337dbfE6A

# The Graph endpoint for ultra-fast activity history
VITE_GRAPH_ENDPOINT=https://api.studio.thegraph.com/query/117578/superlink-usd-vault/v0.0.1

# RPC endpoints with fallback
VITE_RPC_PRIMARY=https://node.mainnet.etherlink.com
VITE_RPC_FALLBACK=https://relay.mainnet.etherlink.com