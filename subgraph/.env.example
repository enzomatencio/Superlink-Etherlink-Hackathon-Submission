# Subgraph Environment Configuration - EXAMPLE

# The Graph Studio deployment key (get your own from thegraph.com/studio)
GRAPH_DEPLOY_KEY=your_deploy_key_here_from_graph_studio

# Contract addresses to index (update with your deployments)
VAULT_ADDRESS=0x1234567890123456789012345678901234567890

# Network configuration (these are fixed for Etherlink)
NETWORK=etherlink
START_BLOCK=22500000

# Subgraph info (update with your subgraph details)
SUBGRAPH_NAME=your-subgraph-name
STUDIO_QUERY_ID=your_studio_query_id